# BanyanBoard API — Environment Variables
# Copy this file to .env and fill in values for local development.
# All configuration is supplied via environment variables (12-Factor App).
# See src/config/index.ts for the full schema with defaults and validation rules.

# ─── Runtime ──────────────────────────────────────────────────────────────────

# Runtime environment. One of: development, test, production.
# Default: development
NODE_ENV=development

# HTTP listen port.
# Default: 3000
PORT=3000

# ─── Service Identity ─────────────────────────────────────────────────────────

# Service name used in structured logs and traces.
# Default: banyanboard-api
SERVICE_NAME=banyanboard-api

# Semantic version of the running build.
# Default: 0.1.0
SERVICE_VERSION=0.1.0

# ─── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string. REQUIRED — the application will refuse to start
# without this value.
DATABASE_URL=postgres://banyan:banyan@localhost:5432/banyanboard

# ─── Logging ──────────────────────────────────────────────────────────────────

# Log verbosity. One of: trace, debug, info, warn, error, fatal.
# Default: info
LOG_LEVEL=info

# Log output format. One of: json, text
# Default: json
LOG_FORMAT=json

# Log output destination. One of: stdout, file, both.
# Default: stdout
LOG_OUTPUT=stdout

# Path to the log file. Required when LOG_OUTPUT is "file" or "both".
# LOG_FILE_PATH=/var/log/banyanboard/api.log

# ─── OpenTelemetry ────────────────────────────────────────────────────────────

# OpenTelemetry Collector endpoint. Optional in development; REQUIRED in production.
# OTEL_EXPORTER_OTLP_ENDPOINT=

# OTLP transport protocol. One of: http/protobuf, grpc.
# Default: http/protobuf
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Override the service name used by OpenTelemetry (defaults to SERVICE_NAME).
# OTEL_SERVICE_NAME=banyanboard-api

# Trace sampler strategy.
# Default: parentbased_traceidratio
OTEL_TRACES_SAMPLER=parentbased_traceidratio

# Sampling ratio (0.0 to 1.0). Recommend 0.1 in production.
# Default: 1.0
OTEL_TRACES_SAMPLER_ARG=1.0

# Disable all OpenTelemetry SDK instrumentation (useful for local dev without a collector).
# Default: false
OTEL_SDK_DISABLED=false
